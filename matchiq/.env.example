# ---------- backend/.env ----------
# football-data.org token (free tier includes the World Cup: live scores,
# standings, full squads + coaches at 10 req/min).
# Register at https://www.football-data.org/client/register
# This is the PRIMARY live-data source.
FOOTBALL_DATA_TOKEN=

# API-Football key from RapidAPI (free tier = 100 req/day, but current
# seasons are excluded on the free plan — secondary/optional source).
RAPIDAPI_KEY=

# Leave both empty to run entirely on the bundled fallback dataset (demo mode).

# --- Watch LIVE button (monetizable) ---
# Where the live broadcast streams (your region's official rights holder).
WATCH_URL=https://www.zee5.com/live-tv
# Affiliate deep-link template from your network (EarnKaro/Cuelinks/etc.).
# {url} = encoded WATCH_URL target, {subid} = per-match tracking id.
# Example (Cuelinks): https://linksredirect.com/?cid=YOURID&source=matchiq&subid={subid}&url={url}
# Leave empty to redirect directly without affiliate wrapping.
AFFILIATE_URL_TEMPLATE=

# Official YouTube channels scanned for highlights (comma-separated channel IDs).
# Default: FIFA. Add your region's broadcaster channel for more coverage.
HIGHLIGHT_CHANNEL_IDS=

# Comma-separated origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ---------- frontend/.env ----------
# Base URL of the FastAPI backend.
VITE_API_URL=http://localhost:8000

# ---------- backend/.env ----------
# football-data.org token (free tier includes the World Cup: live scores,
# standings, full squads + coaches at 10 req/min).
# Register at https://www.football-data.org/client/register
# This is the PRIMARY live-data source.
FOOTBALL_DATA_TOKEN=

# API-Football key from RapidAPI (free tier = 100 req/day, but current
# seasons are excluded on the free plan — secondary/optional source).
RAPIDAPI_KEY=

# Leave both empty to run entirely on the bundled fallback dataset (demo mode).

# Comma-separated origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ---------- frontend/.env ----------
# Base URL of the FastAPI backend.
VITE_API_URL=http://localhost:8000
